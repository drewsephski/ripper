// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output = "../generated/client"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?

  // Better Auth fields
  accounts      Account[]
  sessions      Session[]

  // App builder fields
  projects      Project[]
  settings      UserSettings?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                    String   @id @default(cuid())
  accountId             String
  providerId            String
  type                  String   @default("oauth")
  userId                String
  password              String?  @db.Text
  accessToken           String?  @db.Text
  refreshToken          String?  @db.Text
  idToken               String?  @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  sourceUrl     String?
  style         String   @default("modern")
  status        String   @default("draft")

  // Sandbox state
  sandboxId     String?
  sandboxUrl    String?

  // Generated code storage
  files         File[]

  // Conversation history
  conversations Conversation[]

  // User relation
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model File {
  id          String   @id @default(cuid())
  path        String
  content     String   @db.Text
  language    String?

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([projectId, path])
  @@index([projectId])
}

model Conversation {
  id        String   @id @default(cuid())
  role      String
  content   String   @db.Text

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([projectId])
}

model UserSettings {
  id              String  @id @default(cuid())

  // AI preferences
  defaultModel    String  @default("anthropic/claude-sonnet-4")

  // UI preferences
  theme           String  @default("light")

  // Usage tracking
  projectsCreated Int     @default(0)

  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RateLimit {
  id          String @id @default(cuid())
  key         String @unique
  count       Int    @default(0)
  lastRequest BigInt @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}
